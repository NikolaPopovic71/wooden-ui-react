{
  "name": "wooden-ui-react",
  "version": "1.0.0",
  "description": "Handcrafted React UI components with a skeuomorphic wood texture aesthetic",
  "private": false,
  "type": "module",
  "main": "./dist/wooden-ui.umd.cjs",
  "module": "./dist/wooden-ui.js",
  "exports": {
    ".": {
      "import": "./dist/wooden-ui.js",
      "require": "./dist/wooden-ui.umd.cjs"
    },
    "./style.css": "./dist/style.css"
  },
  "files": ["dist", "README.md"],
  "scripts": {
    "dev": "vite",
    "build": "vite build",
    "build:lib": "vite build --config vite.lib.config.js",
    "lint": "eslint .",
    "preview": "vite preview"
  },
  "keywords": ["react","ui","components","skeuomorphism","wood","toggle","input","button","checkbox","slider","design-system"],
  "author": { "name": "Nikola Popovic", "url": "https://ponitech.pro" },
  "license": "MIT",
  "repository": { "type": "git", "url": "https://github.com/NikolaPopovic71/wooden-ui-react" },
  "homepage": "https://ponitech.pro",
  "bugs": { "url": "https://github.com/NikolaPopovic71/wooden-ui-react/issues" },
  "peerDependencies": {
    "react": ">=18.0.0",
    "react-dom": ">=18.0.0"
  },
  "dependencies": {
    "react": "^19.2.4",
    "react-dom": "^19.2.4"
  },
  "devDependencies": {
    "@eslint/js": "^9.39.4",
    "@types/react": "^19.2.14",
    "@types/react-dom": "^19.2.3",
    "@vitejs/plugin-react": "^6.0.1",
    "eslint": "^9.39.4",
    "eslint-plugin-react-hooks": "^7.0.1",
    "eslint-plugin-react-refresh": "^0.5.2",
    "globals": "^17.4.0",
    "vite": "^8.0.1"
  }
}